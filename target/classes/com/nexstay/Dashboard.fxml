<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nexstay.controller.DashboardController"
      spacing="20"
      style="-fx-background-color: #ffffff;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <!-- ── Welcome heading ──────────────────────────────────────────── -->
    <Label text="Welcome to NexStay"
           style="-fx-font-size: 28px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1a1a1a;" />

    <!-- ── Stat cards row ───────────────────────────────────────────── -->
    <HBox spacing="20">

        <!-- Total Rooms -->
        <VBox styleClass="stat-card" minWidth="200" spacing="8">
            <Label text="Total Rooms"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #6b1a1a;
                          -fx-font-weight: bold;" />
            <Label fx:id="lblTotalRooms"
                   text="0"
                   style="-fx-font-size: 36px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #6b1a1a;" />
        </VBox>

        <!-- Rooms Available -->
        <VBox styleClass="stat-card" minWidth="200" spacing="8">
            <Label text="Rooms Available"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #6b1a1a;
                          -fx-font-weight: bold;" />
            <Label fx:id="lblAvailable"
                   text="0"
                   style="-fx-font-size: 36px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #6b1a1a;" />
        </VBox>

        <!-- Rooms Occupied -->
        <VBox styleClass="stat-card" minWidth="200" spacing="8">
            <Label text="Rooms Occupied"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #6b1a1a;
                          -fx-font-weight: bold;" />
            <Label fx:id="lblOccupied"
                   text="0"
                   style="-fx-font-size: 36px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #6b1a1a;" />
        </VBox>

    </HBox>

    <!-- ── Revenue section ──────────────────────────────────────────── -->
    <Label text="Total Revenue"
           style="-fx-font-size: 18px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #1a1a1a;" />

    <Label fx:id="lblRevenue"
           text="₹ 0.00"
           style="-fx-font-size: 40px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #6b1a1a;" />

</VBox>
