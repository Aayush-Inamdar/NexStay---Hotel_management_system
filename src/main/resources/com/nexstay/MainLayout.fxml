<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nexstay.controller.MainController">

    <!-- ══════════════════════════════════════════════
         LEFT – Sidebar
    ══════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="200"
              spacing="8"
              style="-fx-background-color: #6b1a1a;
                     -fx-border-color: #c9a84c;
                     -fx-border-width: 0 2 0 0;">

            <padding>
                <Insets top="24" right="0" bottom="24" left="0" />
            </padding>

            <!-- Brand label -->
            <Label text="NexStay"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #c9a84c;
                          -fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-alignment: center;
                          -fx-padding: 0 0 20 0;" />

            <!-- Nav buttons -->
            <Button fx:id="btnDashboard"
                    text="Dashboard"
                    maxWidth="Infinity"
                    onAction="#handleDashboard"
                    styleClass="nav-btn" />

            <Button fx:id="btnRooms"
                    text="Rooms"
                    maxWidth="Infinity"
                    onAction="#handleRooms"
                    styleClass="nav-btn" />

            <Button fx:id="btnSmartBook"
                    text="Smart Book"
                    maxWidth="Infinity"
                    onAction="#handleSmartBook"
                    styleClass="nav-btn" />

            <Button fx:id="btnBilling"
                    text="Billing"
                    maxWidth="Infinity"
                    onAction="#handleBilling"
                    styleClass="nav-btn" />

            <Button fx:id="btnCustomers"
                    text="Customers"
                    maxWidth="Infinity"
                    onAction="#handleCustomers"
                    styleClass="nav-btn" />

        </VBox>
    </left>

    <!-- ══════════════════════════════════════════════
         CENTER – Swappable content area
    ══════════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #ffffff;" />
    </center>

</BorderPane>
